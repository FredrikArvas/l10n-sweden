<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_partner_form_l10n_se_partner" model="ir.ui.view">
    <field name="name">res.partner.form.l10n_se_partner</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">

      <xpath expr="//div[@name='partner_address_country']/preceding-sibling::field[@name='city']" position="replace"/>
      <xpath expr="//div[@name='partner_address_country']/preceding-sibling::field[@name='state_id']" position="replace"/>
      <xpath expr="//div[@name='partner_address_country']/preceding-sibling::field[@name='zip']" position="replace"/>

      <xpath expr="//div[@name='partner_address_country']" position="before">
        <field name="zip" placeholder="Postnummer" class="o_address_zip"
            readonly="type == 'contact' and parent_id"/>
        <field name="city" placeholder="Stad" class="o_address_city"
            readonly="type == 'contact' and parent_id"/>
        <field name="state_id" class="o_address_state" placeholder="Lan"
            options="{'no_open': True, 'no_quick_create': True}"
            readonly="type == 'contact' and parent_id"
            context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"/>
      </xpath>

    </field>
  </record>

</odoo>